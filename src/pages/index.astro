---
import BaseLayout from '../layouts/BaseLayout.astro';

const publications = [
  { title: 'Justice Behind the Walls', href: '/publications/justice-behind-the-walls/' },
  { title: 'Prisoners of Isolation', href: '/publications/prisoners-of-isolation/' },
];
---

<BaseLayout title="Justice Behind the Walls">
  <h1>Publications</h1>
  <ul>
    {publications.map(p => (
      <li><a href={p.href}>{p.title}</a></li>
    ))}
  </ul>
</BaseLayout>
