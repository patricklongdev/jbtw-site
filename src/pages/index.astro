---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Justice Behind the Walls">
  <div slot="before-main" class="home-hero">
    <img
      src="/images/JWTW_hero_01.jpg"
      alt="Chain-link fence with razor wire in front of a federal prison building"
      class="home-hero__img"
    />
    <div class="home-hero__overlay">
      <h1 class="home-hero__title">Justice Behind the Walls</h1>
      <p class="home-hero__byline">By Michael Jackson, O.C., Q.C.</p>
    </div>
  </div>

  <section class="home-intro">
    <p>The online home of two foundational works on prisoners' rights and prison law in Canada.</p>
  </section>
</BaseLayout>
