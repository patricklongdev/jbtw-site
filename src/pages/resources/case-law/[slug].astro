---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const cases = await getCollection('case-law');
  return cases.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { case_name, parties, citation, court, body_html } = entry.data;
---

<BaseLayout title={`${case_name} — Case Law`}>
  <nav aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a> <span aria-hidden="true"> › </span></li>
      <li><a href="/resources/">Resources</a> <span aria-hidden="true"> › </span></li>
      <li><a href="/resources/case-law/">Case Law</a> <span aria-hidden="true"> › </span></li>
      <li>{case_name}</li>
    </ol>
  </nav>
  <article class="case-law" data-pagefind-filter="resource:Case Law">
    <header>
      <h1>{case_name}</h1>
      {parties && <p class="parties">{parties}</p>}
      <dl class="meta">
        {citation && <><dt>Citation</dt><dd>{citation}</dd></>}
        {court && <><dt>Court</dt><dd>{court}</dd></>}
      </dl>
    </header>
    <div class="body" set:html={body_html} />
  </article>
</BaseLayout>
