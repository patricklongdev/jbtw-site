---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const all = await getCollection('chapters');
const subsections = all
  .filter(c =>
    c.data.book === 'justice-behind-the-walls' &&
    c.data.chapter_slug === 'introduction' &&
    c.data.subsection_slug != null
  )
  .sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
---

<BaseLayout title="Introduction — Justice Behind the Walls">
  <h1>Introduction</h1>
  <ol>
    {subsections.map(s => (
      <li>
        <a href={`/publications/justice-behind-the-walls/introduction/${s.data.subsection_slug}/`}>
          {s.data.subsection_title}
        </a>
      </li>
    ))}
  </ol>
</BaseLayout>
