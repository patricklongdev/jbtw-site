---
import { getCollection } from 'astro:content';

const allChapters = await getCollection('chapters');

// Deduplicate by chapter_slug — keep lowest chapter_number per slug within each sector
const seen = new Map<string, typeof allChapters[0]>();
for (const c of allChapters) {
  if (c.data.book !== 'justice-behind-the-walls' || !c.data.chapter_slug) continue;
  const key = `${c.data.sector_number}-${c.data.chapter_slug}`;
  const existing = seen.get(key);
  if (!existing || (c.data.chapter_number ?? 999) < (existing.data.chapter_number ?? 999)) {
    seen.set(key, c);
  }
}

const chapters = [...seen.values()].sort((a, b) => {
  const sA = a.data.sector_number ?? 0;
  const sB = b.data.sector_number ?? 0;
  if (sA !== sB) return sA - sB;
  return (a.data.chapter_number ?? 0) - (b.data.chapter_number ?? 0);
});

const bySector = chapters.reduce<Record<string, typeof chapters>>((acc, c) => {
  const key = c.data.sector ?? 'Other';
  (acc[key] ??= []).push(c);
  return acc;
}, {});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Justice Behind the Walls</title>
  </head>
  <body>
    <main>
      <h1>Justice Behind the Walls</h1>
      {Object.entries(bySector).map(([sector, cs]) => (
        <section>
          <h2>{sector}</h2>
          <ol>
            {cs.map(c => (
              <li>
                <a href={`/publications/justice-behind-the-walls/sector-${c.data.sector_number}/chapter-${c.data.chapter_slug}/`}>
                  {c.data.chapter}
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </main>
  </body>
</html>
