---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allChapters = await getCollection('chapters');

// ── Introduction ─────────────────────────────────────────────────────────────
const introSubs = allChapters
  .filter(c =>
    c.data.book === 'justice-behind-the-walls' &&
    c.data.chapter_slug === 'introduction' &&
    c.data.subsection_slug != null
  )
  .sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));

// ── Sectors 1–6: all sub-sections grouped by chapter ─────────────────────────
type Entry = typeof allChapters[number];
interface ChapterGroup {
  sector: string;
  sectorNum: number;
  chapterSlug: string;
  chapterName: string;
  chapterNumber: number;
  subsections: Entry[];
}

const chapterMap = new Map<string, ChapterGroup>();
for (const c of allChapters) {
  if (
    c.data.book !== 'justice-behind-the-walls' ||
    !c.data.chapter_slug ||
    c.data.sector_number == null ||
    !c.data.subsection_slug
  ) continue;
  const key = `${c.data.sector_number}-${c.data.chapter_slug}`;
  if (!chapterMap.has(key)) {
    chapterMap.set(key, {
      sector: c.data.sector ?? 'Other',
      sectorNum: c.data.sector_number,
      chapterSlug: c.data.chapter_slug,
      chapterName: c.data.chapter ?? c.data.title,
      chapterNumber: Number(c.data.chapter_number) || 0,
      subsections: [],
    });
  }
  chapterMap.get(key)!.subsections.push(c);
}
for (const ch of chapterMap.values()) {
  ch.subsections.sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
}
const sortedChapters = [...chapterMap.values()].sort((a, b) =>
  a.sectorNum !== b.sectorNum ? a.sectorNum - b.sectorNum : a.chapterNumber - b.chapterNumber
);
const bySector = sortedChapters.reduce<Record<string, ChapterGroup[]>>((acc, ch) => {
  (acc[ch.sector] ??= []).push(ch);
  return acc;
}, {});

// ── Conclusion ────────────────────────────────────────────────────────────────
const conclusionSubs = allChapters
  .filter(c =>
    c.data.book === 'justice-behind-the-walls' &&
    c.data.chapter_slug === 'conclusion' &&
    c.data.subsection_slug != null
  )
  .sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
---

<BaseLayout title="Justice Behind the Walls">
      <h1>Justice Behind the Walls</h1>

      {/* Introduction */}
      <section>
        <h2>Introduction</h2>
        <ol>
          {introSubs.map(s => (
            <li>
              <a href={`/publications/justice-behind-the-walls/introduction/${s.data.subsection_slug}/`}>
                {s.data.subsection_title}
              </a>
            </li>
          ))}
        </ol>
      </section>

      {/* Sectors 1–6 */}
      {Object.entries(bySector).map(([sector, chapters]) => (
        <section>
          <h2>{sector}</h2>
          <ol>
            {chapters.map(ch => (
              <li>
                {ch.subsections.length === 1 ? (
                  <a href={`/publications/justice-behind-the-walls/sector-${ch.sectorNum}/chapter-${ch.chapterSlug}/`}>
                    {ch.chapterName}
                  </a>
                ) : (
                  <>
                    <span>{ch.chapterName}</span>
                    <ol>
                      {ch.subsections.map(s => (
                        <li>
                          <a href={`/publications/justice-behind-the-walls/sector-${ch.sectorNum}/chapter-${ch.chapterSlug}/${s.data.subsection_slug}/`}>
                            {s.data.subsection_title}
                          </a>
                        </li>
                      ))}
                    </ol>
                  </>
                )}
              </li>
            ))}
          </ol>
        </section>
      ))}

      {/* Conclusion */}
      {conclusionSubs.length > 0 && (
        <section>
          <h2>Conclusion</h2>
          <ol>
            {conclusionSubs.map(s => (
              <li>
                <a href="/publications/justice-behind-the-walls/conclusion/">
                  {s.data.subsection_title}
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}
</BaseLayout>
