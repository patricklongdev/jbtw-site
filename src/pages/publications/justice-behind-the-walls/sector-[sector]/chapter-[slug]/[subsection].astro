---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../../../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const allChapters = await getCollection('chapters');

  const byChapter = new Map<string, typeof allChapters>();
  for (const c of allChapters) {
    if (
      c.data.book !== 'justice-behind-the-walls' ||
      c.data.sector_number == null ||
      !c.data.chapter_slug ||
      !c.data.subsection_slug
    ) continue;
    const key = `${c.data.sector_number}-${c.data.chapter_slug}`;
    if (!byChapter.has(key)) byChapter.set(key, []);
    byChapter.get(key)!.push(c);
  }

  const paths = [];
  for (const siblings of byChapter.values()) {
    siblings.sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
    for (let i = 0; i < siblings.length; i++) {
      const c = siblings[i];
      const baseUrl = `/publications/justice-behind-the-walls/sector-${c.data.sector_number}/chapter-${c.data.chapter_slug}`;
      paths.push({
        params: {
          sector:     String(c.data.sector_number),
          slug:       c.data.chapter_slug!,
          subsection: c.data.subsection_slug!,
        },
        props: {
          chapter: c,
          prev: i > 0 ? {
            title: siblings[i - 1].data.subsection_title ?? siblings[i - 1].data.title,
            href: `${baseUrl}/${siblings[i - 1].data.subsection_slug}/`,
          } : null,
          next: i < siblings.length - 1 ? {
            title: siblings[i + 1].data.subsection_title ?? siblings[i + 1].data.title,
            href: `${baseUrl}/${siblings[i + 1].data.subsection_slug}/`,
          } : null,
        },
      });
    }
  }
  return paths;
}

const { chapter, prev, next } = Astro.props;
const { Content } = await render(chapter);
---

<ChapterLayout frontmatter={chapter.data} prev={prev} next={next}>
  <Content />
</ChapterLayout>
