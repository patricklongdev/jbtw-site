---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  return chapters
    .filter(c => c.data.book === 'justice-behind-the-walls' && c.data.sector_number != null && c.data.chapter_slug != null)
    .map(c => ({
      params: {
        sector: String(c.data.sector_number),
        slug: c.data.chapter_slug,
      },
      props: { chapter: c },
    }));
}

const { chapter } = Astro.props;
const { Content } = await render(chapter);
---

<ChapterLayout frontmatter={chapter.data}>
  <Content />
</ChapterLayout>
