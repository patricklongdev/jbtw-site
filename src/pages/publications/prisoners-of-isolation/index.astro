---
import { getCollection } from 'astro:content';

const allChapters = await getCollection('chapters');

// ── Preface ──────────────────────────────────────────────────────────────────
const prefaceSubs = allChapters
  .filter(c =>
    c.data.book === 'prisoners-of-isolation' &&
    c.data.chapter_slug === 'preface' &&
    c.data.subsection_slug != null
  )
  .sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));

// ── Chapters 1–7: deduplicate by chapter_slug, keep first sub-section ────────
const seen = new Map<string, typeof allChapters[0]>();
for (const c of allChapters) {
  if (
    c.data.book !== 'prisoners-of-isolation' ||
    !c.data.chapter_slug ||
    c.data.chapter_slug === 'preface' ||
    !c.data.subsection_slug
  ) continue;
  const existing = seen.get(c.data.chapter_slug);
  if (!existing || (Number(c.data.chapter_number) ?? 999) < (Number(existing.data.chapter_number) ?? 999)) {
    seen.set(c.data.chapter_slug, c);
  }
}
const chapters = [...seen.values()].sort(
  (a, b) => (Number(a.data.chapter_number) ?? 0) - (Number(b.data.chapter_number) ?? 0)
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prisoners of Isolation</title>
  </head>
  <body>
    <main>
      <h1>Prisoners of Isolation: Solitary Confinement in Canada</h1>

      {/* Preface */}
      {prefaceSubs.length > 0 && (
        <section>
          <h2>Preface</h2>
          <ol>
            {prefaceSubs.map(s => (
              <li>
                <a href={`/publications/prisoners-of-isolation/preface/${s.data.subsection_slug}/`}>
                  {s.data.subsection_title}
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}

      {/* Chapters */}
      <section>
        <ol>
          {chapters.map(c => (
            <li>
              <a href={`/publications/prisoners-of-isolation/chapter-${c.data.chapter_slug}/`}>
                {c.data.chapter}
              </a>
            </li>
          ))}
        </ol>
      </section>
    </main>
  </body>
</html>
