---
import { getCollection } from 'astro:content';

const allChapters = await getCollection('chapters');

// Deduplicate by chapter_slug — keep lowest chapter_number per slug
const seen = new Map<string, typeof allChapters[0]>();
for (const c of allChapters) {
  if (c.data.book !== 'prisoners-of-isolation' || !c.data.chapter_slug) continue;
  const existing = seen.get(c.data.chapter_slug);
  if (!existing || (c.data.chapter_number ?? 999) < (existing.data.chapter_number ?? 999)) {
    seen.set(c.data.chapter_slug, c);
  }
}
const chapters = [...seen.values()].sort((a, b) => (a.data.chapter_number ?? 0) - (b.data.chapter_number ?? 0));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prisoners of Isolation</title>
  </head>
  <body>
    <main>
      <h1>Prisoners of Isolation: Solitary Confinement in Canada</h1>
      <ol>
        {chapters.map(c => (
          <li>
            <a href={`/publications/prisoners-of-isolation/chapter-${c.data.chapter_slug}/`}>
              {c.data.chapter}
            </a>
          </li>
        ))}
      </ol>
    </main>
  </body>
</html>
