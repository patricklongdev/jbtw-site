---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allChapters = await getCollection('chapters');

// ── Preface ───────────────────────────────────────────────────────────────────
const prefaceSubs = allChapters
  .filter(c =>
    c.data.book === 'prisoners-of-isolation' &&
    c.data.chapter_slug === 'preface' &&
    c.data.subsection_slug != null
  )
  .sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));

// ── Chapters 1–7: all sub-sections grouped by chapter ────────────────────────
type Entry = typeof allChapters[number];
interface ChapterGroup {
  chapterSlug: string;
  chapterName: string;
  chapterNumber: number;
  subsections: Entry[];
}

const chapterMap = new Map<string, ChapterGroup>();
for (const c of allChapters) {
  if (
    c.data.book !== 'prisoners-of-isolation' ||
    !c.data.chapter_slug ||
    c.data.chapter_slug === 'preface' ||
    !c.data.subsection_slug
  ) continue;
  const key = c.data.chapter_slug;
  if (!chapterMap.has(key)) {
    chapterMap.set(key, {
      chapterSlug: c.data.chapter_slug,
      chapterName: c.data.chapter ?? c.data.title,
      chapterNumber: Number(c.data.chapter_number) || 0,
      subsections: [],
    });
  }
  chapterMap.get(key)!.subsections.push(c);
}
for (const ch of chapterMap.values()) {
  ch.subsections.sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
}
const chapters = [...chapterMap.values()].sort((a, b) => a.chapterNumber - b.chapterNumber);
---

<BaseLayout title="Prisoners of Isolation">
      <h1>Prisoners of Isolation: Solitary Confinement in Canada</h1>

      {/* Preface */}
      {prefaceSubs.length > 0 && (
        <section>
          <h2>Preface</h2>
          <ol>
            {prefaceSubs.map(s => (
              <li>
                <a href={`/publications/prisoners-of-isolation/preface/${s.data.subsection_slug}/`}>
                  {s.data.subsection_title}
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}

      {/* Chapters */}
      <section>
        <ol>
          {chapters.map(ch => (
            <li>
              {ch.subsections.length === 1 ? (
                <a href={`/publications/prisoners-of-isolation/chapter-${ch.chapterSlug}/`}>
                  {ch.chapterName}
                </a>
              ) : (
                <>
                  <span>{ch.chapterName}</span>
                  <ol>
                    {ch.subsections.map(s => (
                      <li>
                        <a href={`/publications/prisoners-of-isolation/chapter-${ch.chapterSlug}/${s.data.subsection_slug}/`}>
                          {s.data.subsection_title}
                        </a>
                      </li>
                    ))}
                  </ol>
                </>
              )}
            </li>
          ))}
        </ol>
      </section>
</BaseLayout>
