---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../../layouts/ChapterLayout.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allChapters = await getCollection('chapters');

  type Entry = typeof allChapters[number];

  function sortKey(c: Entry): [number, number] {
    const chapOrder = c.data.chapter_slug === 'preface' ? 0 : (Number(c.data.chapter_number) || 0);
    return [chapOrder, c.data.subsection_number ?? 0];
  }

  function navLink(c: Entry) {
    const label = c.data.subsection_title ?? c.data.title;
    const slug = c.data.chapter_slug;
    const href = slug === 'preface'
      ? `/publications/prisoners-of-isolation/preface/${c.data.subsection_slug}/`
      : `/publications/prisoners-of-isolation/chapter-${slug}/${c.data.subsection_slug}/`;
    return { title: label, href };
  }

  // Full book-wide sequence (preface → chapters 1-7)
  const poiAll = allChapters
    .filter(c => c.data.book === 'prisoners-of-isolation' && c.data.subsection_slug != null)
    .sort((a, b) => {
      const [ca, ua] = sortKey(a);
      const [cb, ub] = sortKey(b);
      return ca !== cb ? ca - cb : ua - ub;
    });

  const byChapter = new Map<string, typeof allChapters>();
  for (const c of allChapters) {
    if (
      c.data.book !== 'prisoners-of-isolation' ||
      !c.data.chapter_slug ||
      !c.data.subsection_slug ||
      c.data.chapter_slug === 'preface'
    ) continue;
    const key = c.data.chapter_slug;
    if (!byChapter.has(key)) byChapter.set(key, []);
    byChapter.get(key)!.push(c);
  }

  return [...byChapter.values()].map(subsections => {
    subsections.sort((a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0));
    const first = subsections[0];

    // For single-sub-section chapters, compute prev/next from the global sequence
    let prev = null, next = null;
    if (subsections.length === 1) {
      const i = poiAll.indexOf(first);
      prev = i > 0 ? navLink(poiAll[i - 1]) : null;
      next = i < poiAll.length - 1 ? navLink(poiAll[i + 1]) : null;
    }

    return {
      params: { slug: first.data.chapter_slug! },
      props: { subsections, prev, next },
    };
  });
}

const { subsections, prev, next } = Astro.props;
const first = subsections[0];
const chapterTitle = first.data.chapter ?? first.data.title;

let singleContent: Awaited<ReturnType<typeof render>> | null = null;
if (subsections.length === 1) {
  singleContent = await render(first);
}
---

{singleContent ? (
  <ChapterLayout frontmatter={first.data} prev={prev} next={next}>
    <singleContent.Content />
  </ChapterLayout>
) : (
  <BaseLayout title={chapterTitle}>
    <h1>{chapterTitle}</h1>
    <ol>
      {subsections.map(s => (
        <li>
          <a href={`/publications/prisoners-of-isolation/chapter-${first.data.chapter_slug}/${s.data.subsection_slug}/`}>
            {s.data.subsection_title}
          </a>
        </li>
      ))}
    </ol>
  </BaseLayout>
)}
