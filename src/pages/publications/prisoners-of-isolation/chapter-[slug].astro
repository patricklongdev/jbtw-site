---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const allChapters = await getCollection('chapters');

  const byChapter = new Map<string, {
    slug: string;
    subsections: typeof allChapters;
  }>();

  for (const c of allChapters) {
    if (
      c.data.book !== 'prisoners-of-isolation' ||
      !c.data.chapter_slug ||
      !c.data.subsection_slug ||
      c.data.chapter_slug === 'preface'
    ) continue;

    const key = c.data.chapter_slug;
    if (!byChapter.has(key)) {
      byChapter.set(key, { slug: key, subsections: [] });
    }
    byChapter.get(key)!.subsections.push(c);
  }

  return [...byChapter.values()].map(({ slug, subsections }) => ({
    params: { slug },
    props: {
      subsections: subsections.sort(
        (a, b) => (a.data.subsection_number ?? 0) - (b.data.subsection_number ?? 0)
      ),
    },
  }));
}

const { subsections } = Astro.props;
const first = subsections[0];
const chapterTitle = first.data.chapter ?? first.data.title;

let singleContent: Awaited<ReturnType<typeof render>> | null = null;
if (subsections.length === 1) {
  singleContent = await render(first);
}
---

{singleContent ? (
  <ChapterLayout frontmatter={first.data}>
    <singleContent.Content />
  </ChapterLayout>
) : (
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{chapterTitle}</title>
    </head>
    <body>
      <main>
        <h1>{chapterTitle}</h1>
        <ol>
          {subsections.map(s => (
            <li>
              <a href={`/publications/prisoners-of-isolation/chapter-${first.data.chapter_slug}/${s.data.subsection_slug}/`}>
                {s.data.subsection_title}
              </a>
            </li>
          ))}
        </ol>
      </main>
    </body>
  </html>
)}
