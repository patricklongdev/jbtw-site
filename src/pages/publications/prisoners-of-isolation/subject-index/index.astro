---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BookTabs from '../../../../components/BookTabs.astro';
import indexDataRaw from '../../../../data/index-poi.json';

const indexData = indexDataRaw as { term: string; refs: { href: string }[] }[];

const allChapters = await getCollection('chapters');
const poiChapters = allChapters.filter(c => c.data.book === 'prisoners-of-isolation');

// Count subsections per chapter
const chapterSubcounts = new Map<string, number>();
for (const c of poiChapters) {
  if (!c.data.chapter_slug || !c.data.subsection_slug) continue;
  chapterSubcounts.set(c.data.chapter_slug, (chapterSubcounts.get(c.data.chapter_slug) ?? 0) + 1);
}

function buildUrl(c: typeof poiChapters[number]): string {
  const base = '/publications/prisoners-of-isolation';
  const { chapter_slug: cs, subsection_slug: ss } = c.data;
  if (cs === 'preface') return `${base}/preface/${ss}/`;
  const isSingle = (chapterSubcounts.get(cs!) ?? 1) === 1;
  if (isSingle) return `${base}/chapter-${cs}/`;
  return `${base}/chapter-${cs}/${ss}/`;
}

// CID → {url, title}
const cidMap = new Map<string, { url: string; title: string }>();
for (const c of poiChapters) {
  if (!c.data.cid) continue;
  cidMap.set(String(c.data.cid), {
    url: buildUrl(c),
    title: c.data.subsection_title || c.data.title || '',
  });
}

function extractCid(href: string): string | null {
  return href.match(/[?&]cid=(\d+)/)?.[1] ?? null;
}

function groupLetter(term: string): string {
  const ch = term.trim()[0]?.toUpperCase() ?? '#';
  return /[A-Z]/.test(ch) ? ch : '#';
}

interface IndexEntry { term: string; letter: string; links: { url: string; title: string }[] }
const processedTerms: IndexEntry[] = [];

for (const entry of indexData) {
  const term = entry.term.trim();
  const seenCids = new Set<string>();
  const links: { url: string; title: string }[] = [];
  for (const ref of entry.refs) {
    const cid = extractCid(ref.href);
    if (!cid || seenCids.has(cid)) continue;
    seenCids.add(cid);
    const mapped = cidMap.get(cid);
    if (mapped) links.push(mapped);
  }
  if (links.length === 0) continue;
  processedTerms.push({ term, letter: groupLetter(term), links });
}

const grouped = new Map<string, IndexEntry[]>();
for (const e of processedTerms) {
  (grouped.get(e.letter) ?? grouped.set(e.letter, []).get(e.letter)!).push(e);
}
const letters = [...grouped.keys()].sort();
---

<BaseLayout title="Subject Index — Prisoners of Isolation">
  <div class="index-page">
    <h1>Prisoners of Isolation</h1>
    <BookTabs base="/publications/prisoners-of-isolation" />

    <nav class="alpha-nav" aria-label="Jump to letter">
      {letters.map(l => <a href={`#letter-${l}`}>{l}</a>)}
    </nav>

    {letters.map(letter => (
      <section class="alpha-section" id={`letter-${letter}`}>
        <h2 class="alpha-heading">{letter}</h2>
        <dl class="index-list">
          {grouped.get(letter)!.map(entry => (
            <>
              <dt>{entry.term}</dt>
              <dd>
                {entry.links.map((link, i) => (
                  <>
                    {i > 0 && <span class="ref-sep"> · </span>}
                    <a href={link.url}>{link.title}</a>
                  </>
                ))}
              </dd>
            </>
          ))}
        </dl>
      </section>
    ))}
  </div>
</BaseLayout>
