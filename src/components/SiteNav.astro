---
const { pathname } = Astro.url;

const links = [
  { label: 'About', href: '/about/' },
  { label: 'Publications', href: '/publications/' },
  { label: 'Gallery', href: '/gallery/' },
  { label: 'Resources', href: '/resources/' },
  { label: 'Contact', href: '/contact/' },
];
---

<nav class="site-nav" aria-label="Site navigation">
  <a href="/" class="site-nav__logo" aria-label="Justice Behind the Walls — home">
    <img src="/jbtw-logo.svg" alt="Justice Behind the Walls" />
  </a>

  <button class="site-nav__search" id="search-toggle" aria-label="Search" aria-expanded="false">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="7.5" cy="7.5" r="5.5"/>
      <line x1="12" y1="12" x2="16.5" y2="16.5"/>
    </svg>
  </button>

  <button class="site-nav__burger" aria-expanded="false" aria-controls="site-nav-links" aria-label="Open menu">
    <span></span><span></span><span></span>
  </button>

  <ul class="site-nav__links" id="site-nav-links">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const burger = document.querySelector('.site-nav__burger') as HTMLButtonElement;
  const menu   = document.getElementById('site-nav-links')!;

  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    menu.classList.toggle('is-open', !open);
  });
</script>
