---
import SiteNav from '../components/SiteNav.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <SiteNav />
    <slot name="before-main" />
    <main>
      <slot />
    </main>
  </body>
</html>
