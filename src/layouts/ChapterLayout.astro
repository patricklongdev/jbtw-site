---
import SiteNav from '../components/SiteNav.astro';
type NavLink = { title: string; href: string };

interface Props {
  frontmatter: {
    title: string;
    book: string;
    sector_number?: number | null;
    chapter?: string | null;
    chapter_slug?: string | null;
    subsection_title?: string | null;
    has_footnotes?: boolean;
    [key: string]: unknown;
  };
  prev?: NavLink | null;
  next?: NavLink | null;
}

const { frontmatter, prev, next } = Astro.props;
const { title, book, sector_number, chapter, chapter_slug, subsection_title } = frontmatter;
const subsection_slug = frontmatter.subsection_slug as string | undefined;
// Detect single-sub-section: slugs match, or display names are identical
const isSingleSubsection =
  (!!chapter_slug && chapter_slug === subsection_slug) ||
  (!!chapter && !!subsection_title && chapter.toLowerCase() === subsection_title.toLowerCase());

const bookTitle = book === 'justice-behind-the-walls'
  ? 'Justice Behind the Walls'
  : 'Prisoners of Isolation';
const bookUrl = `/publications/${book}/`;

function chapterUrl(): string {
  if (!chapter_slug) return bookUrl;
  if (book === 'justice-behind-the-walls') {
    if (chapter_slug === 'introduction') return '/publications/justice-behind-the-walls/introduction/';
    if (chapter_slug === 'conclusion') return '/publications/justice-behind-the-walls/conclusion/';
    return `/publications/justice-behind-the-walls/sector-${sector_number}/chapter-${chapter_slug}/`;
  }
  if (chapter_slug === 'preface') return '/publications/prisoners-of-isolation/preface/';
  return `/publications/prisoners-of-isolation/chapter-${chapter_slug}/`;
}

const sectorCrumb: Array<{ label: string; href?: string }> =
  book === 'justice-behind-the-walls' && sector_number
    ? [{ label: `Sector ${sector_number}` }]
    : [];

const crumbs: Array<{ label: string; href?: string }> = [
  { label: 'Home', href: '/' },
  { label: bookTitle, href: bookUrl },
  ...sectorCrumb,
  ...(chapter
    ? isSingleSubsection
      ? [{ label: chapter }]
      : [{ label: chapter, href: chapterUrl() }, { label: subsection_title ?? title }]
    : [{ label: subsection_title ?? title }]
  ),
];

const pageTitle = subsection_title
  ? `${subsection_title} — ${bookTitle}`
  : title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <SiteNav />

    <div class="search-overlay" id="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Search">
      <div class="search-modal">
        <div id="search"></div>
      </div>
    </div>

    <header>
      <nav aria-label="Breadcrumb">
        <ol>
          {crumbs.map((crumb, i) => (
            <li>
              {crumb.href
                ? <a href={crumb.href}>{crumb.label}</a>
                : crumb.label}
              {i < crumbs.length - 1 && <span aria-hidden="true"> › </span>}
            </li>
          ))}
        </ol>
      </nav>
    </header>
    <main data-pagefind-body data-pagefind-filter={`publication:${bookTitle}`}>
      <h1>{subsection_title ?? title}</h1>
      <slot />
      {(prev || next) && (
        <nav aria-label="Sub-section navigation">
          {prev && <a href={prev.href} rel="prev">← {prev.title}</a>}
          {next && <a href={next.href} rel="next">{next.title} →</a>}
        </nav>
      )}
    </main>
    <script>
      const searchOverlay = document.getElementById('search-overlay');
      const searchToggle  = document.getElementById('search-toggle');
      let pagefindLoaded  = false;

      function openSearch() {
        if (!searchOverlay) return;
        searchOverlay.hidden = false;
        document.body.style.overflow = 'hidden';
        searchToggle?.setAttribute('aria-expanded', 'true');

        if (!pagefindLoaded) {
          pagefindLoaded = true;

          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = '/pagefind/pagefind-ui.css';
          document.head.appendChild(link);

          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = () => {
            new (window as any).PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
            setTimeout(() => {
              const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
              if (input) input.placeholder = 'Search';
            }, 50);
            focusInput();
          };
          document.head.appendChild(script);
        } else {
          focusInput();
        }
      }

      function focusInput() {
        setTimeout(() => {
          searchOverlay?.querySelector<HTMLInputElement>('input[type="text"]')?.focus();
        }, 60);
      }

      function closeSearch() {
        if (!searchOverlay) return;
        searchOverlay.hidden = true;
        document.body.style.overflow = '';
        searchToggle?.setAttribute('aria-expanded', 'false');
      }

      searchToggle?.addEventListener('click', openSearch);
      searchOverlay?.addEventListener('click', e => { if (e.target === searchOverlay) closeSearch(); });

      document.addEventListener('keydown', e => {
        if (!searchOverlay) return;
        if (e.key === 'Escape' && !searchOverlay.hidden) { closeSearch(); return; }
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
      });
    </script>
    <script is:inline>
      // Hoist sub-section nav before footnotes when both are present
      const nav = document.querySelector('nav[aria-label="Sub-section navigation"]');
      const footnotes = document.querySelector('[data-footnotes]');
      if (nav && footnotes) footnotes.before(nav);
    </script>
  </body>
</html>
