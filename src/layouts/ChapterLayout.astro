---
type NavLink = { title: string; href: string };

interface Props {
  frontmatter: {
    title: string;
    book: string;
    sector_number?: number | null;
    chapter?: string | null;
    chapter_slug?: string | null;
    subsection_title?: string | null;
    has_footnotes?: boolean;
    [key: string]: unknown;
  };
  prev?: NavLink | null;
  next?: NavLink | null;
}

const { frontmatter, prev, next } = Astro.props;
const { title, book, sector_number, chapter, chapter_slug, subsection_title } = frontmatter;
const subsection_slug = frontmatter.subsection_slug as string | undefined;
// Single-sub-section chapters share the same slug for chapter and subsection
const isSingleSubsection = !!chapter_slug && chapter_slug === subsection_slug;

const bookTitle = book === 'justice-behind-the-walls'
  ? 'Justice Behind the Walls'
  : 'Prisoners of Isolation';
const bookUrl = `/publications/${book}/`;

function chapterUrl(): string {
  if (!chapter_slug) return bookUrl;
  if (book === 'justice-behind-the-walls') {
    if (chapter_slug === 'introduction') return '/publications/justice-behind-the-walls/introduction/';
    if (chapter_slug === 'conclusion') return '/publications/justice-behind-the-walls/conclusion/';
    return `/publications/justice-behind-the-walls/sector-${sector_number}/chapter-${chapter_slug}/`;
  }
  if (chapter_slug === 'preface') return '/publications/prisoners-of-isolation/preface/';
  return `/publications/prisoners-of-isolation/chapter-${chapter_slug}/`;
}

const crumbs: Array<{ label: string; href?: string }> = [
  { label: 'Home', href: '/' },
  { label: bookTitle, href: bookUrl },
  ...(chapter
    ? isSingleSubsection
      ? [{ label: chapter }]
      : [{ label: chapter, href: chapterUrl() }, { label: subsection_title ?? title }]
    : [{ label: subsection_title ?? title }]
  ),
];

const pageTitle = subsection_title
  ? `${subsection_title} — ${bookTitle}`
  : title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body>
    <header>
      <div id="search"></div>
      <nav aria-label="Breadcrumb">
        <ol>
          {crumbs.map((crumb, i) => (
            <li>
              {crumb.href
                ? <a href={crumb.href}>{crumb.label}</a>
                : crumb.label}
              {i < crumbs.length - 1 && <span aria-hidden="true"> › </span>}
            </li>
          ))}
        </ol>
      </nav>
    </header>
    <main data-pagefind-body>
      <h1>{subsection_title ?? title}</h1>
      <slot />
      {(prev || next) && (
        <nav aria-label="Sub-section navigation">
          {prev && <a href={prev.href} rel="prev">← {prev.title}</a>}
          {next && <a href={next.href} rel="next">{next.title} →</a>}
        </nav>
      )}
    </main>
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      new PagefindUI({ element: '#search', showSubResults: true });
      // Hoist sub-section nav before footnotes when both are present
      const nav = document.querySelector('nav[aria-label="Sub-section navigation"]');
      const footnotes = document.querySelector('[data-footnotes]');
      if (nav && footnotes) footnotes.before(nav);
    </script>
  </body>
</html>
